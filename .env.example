# ============================================================
# Cloud Resource Map — Credentials Template
# ============================================================
# 1. Copy this file and rename it to:  .env
# 2. Fill in your credentials below
# 3. Run:  docker compose up
# ============================================================
# NEVER commit your .env file to GitHub.
# It is already listed in .gitignore for your protection.
# ============================================================


# ---- AWS (Required to scan AWS) ----------------------------
# How to get these:
#   AWS Console > IAM > Users > Your user > Security credentials
#   Then click "Create access key"
#
AWS_ACCESS_KEY_ID=your_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_secret_access_key_here
AWS_DEFAULT_REGION=us-east-1


# ---- AZURE (Optional — Required to scan Azure) ----------------
# How to get these: see README.md > "Connecting Azure"
#
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=


# ---- GCP (Optional — Required to scan GCP) ------------------
# How to get these: see README.md > "Connecting GCP"
# Paste the full contents of your service account JSON key below
# (paste everything on one line, or use the file path method in README)
#
GCP_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS_JSON=
